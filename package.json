{
  "name": "git-it-together",
  "version": "1.0.0",
  "description": "Interactive CLI tutorial for learning Git in AI-assisted workflows",
  "type": "module",
  "bin": {
    "git-it-together": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build && chmod +x dist/cli.js",
    "test": "tsc --noEmit"
  },
  "keywords": [
    "git",
    "tutorial",
    "cli",
    "ai",
    "learn",
    "interactive"
  ],
  "author": "Vanessa Wang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vvanessaww/git-it-together.git"
  },
  "homepage": "https://github.com/vvanessaww/git-it-together",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "figures": "^6.1.0",
    "ink": "^5.2.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.6",
    "@types/react": "^19.0.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
